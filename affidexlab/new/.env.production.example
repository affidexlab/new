# DecaFlow Production Environment Configuration

# Environment
NODE_ENV=production
ENVIRONMENT=production

# Server
PORT=3000

# CORS - Allowed Origins (comma-separated, no spaces)
ALLOWED_ORIGINS=https://decaflow.xyz,https://decaflow.vercel.app,https://tychiwallet.com,https://app.tychiwallet.com,https://partners.decaflow.xyz

# API Keys
SOCKET_API_KEY=your_socket_api_key_here
ZEROX_API_KEY=your_0x_api_key_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Database (if using external DB in future)
# DATABASE_URL=postgresql://user:pass@host:5432/decaflow

# Redis (if using for caching/rate limiting in future)
# REDIS_URL=redis://host:6379

# Monitoring
# SENTRY_DSN=your_sentry_dsn_here
# DATADOG_API_KEY=your_datadog_key_here

# Feature Flags
ENABLE_SOCKET_BRIDGE=true
ENABLE_AERODROME=true
ENABLE_LIFI_BRIDGE=false
