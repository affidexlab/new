# DecaFlow Sandbox Environment Configuration

# Environment
NODE_ENV=production
ENVIRONMENT=sandbox

# Server
PORT=3000

# CORS - Allowed Origins (comma-separated, no spaces)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,https://partners-sandbox.decaflow.xyz,https://test.tychiwallet.com

# API Keys (use test/sandbox keys)
SOCKET_API_KEY=your_sandbox_socket_api_key_here
ZEROX_API_KEY=your_sandbox_0x_api_key_here

# Rate Limiting (more lenient for testing)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=200

# Logging (more verbose)
LOG_LEVEL=debug

# Feature Flags (enable experimental features)
ENABLE_SOCKET_BRIDGE=true
ENABLE_AERODROME=true
ENABLE_LIFI_BRIDGE=true
ENABLE_DEBUG_MODE=true
