{
  "name": "decaflow-api-server",
  "version": "1.0.0",
  "description": "DecaFlow Partner API - REST API for swaps, liquidity, and bridges",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "start:sandbox": "ENVIRONMENT=sandbox node src/server.js",
    "build": "node --check src/server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.12.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "node-fetch": "^3.3.2",
    "pg": "^8.11.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
