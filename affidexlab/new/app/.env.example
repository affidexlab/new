# WalletConnect Project ID (REQUIRED)
# Get from: https://cloud.walletconnect.com/
VITE_WALLETCONNECT_PROJECT_ID=bb466d3ee706ec7ccd389d161d64005a

# Backend API URL (REQUIRED for bridging)
# Example: https://decaflow-backend.onrender.com
VITE_BACKEND_URL=https://decaflow-backend.onrender.com

# Treasury Wallet Address (receives 0.8% protocol fees)
# Default: 0x65b7a307a7e67e38840b91f9a36bf8dfe6e02901
VITE_TREASURY_WALLET=0x65b7a307a7e67e38840b91f9a36bf8dfe6e02901
