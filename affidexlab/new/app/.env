# WalletConnect Project ID
# Get a FREE project ID at: https://cloud.walletconnect.com
# 1. Sign up or log in
# 2. Create a new project
# 3. Copy the Project ID and paste it below
# 
# IMPORTANT: The current ID below may be expired or invalid
# This causes WalletConnect-based wallets to fail
# Replace it with YOUR OWN project ID for proper wallet support
VITE_WALLETCONNECT_PROJECT_ID=459eaeff6b6ccb624b0560abeb84b9e8
VITE_REOWN_PROJECT_ID=459eaeff6b6ccb624b0560abeb84b9e8

# API Base URL
VITE_API_BASE_URL=https://decaflow-backend.onrender.com

# Socket API Key (Optional - required for bridge functionality)
# Get your API key from https://socket.tech
# Uncomment and add your key to enable Socket bridge
# VITE_SOCKET_API_KEY=
