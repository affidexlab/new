  "repository": {
    "type": "git",
    "url": "https://github.com/decaflow/partner-sdk"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
