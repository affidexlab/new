{
  "name": "@decaflow/partner-sdk",
  "version": "1.0.0",
  "description": "Official DecaFlow Partner SDK for integrating swaps, liquidity, and bridges",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
