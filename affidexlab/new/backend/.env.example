# Socket API Key (REQUIRED for bridge proxy)
# Get from: https://api.socket.tech/
SOCKET_API_KEY=your_socket_api_key_here

# Server Port (default: 3000)
PORT=3000

# Node Environment
NODE_ENV=production

# Allowed CORS Origins (comma-separated)
# Must include your frontend domains
ALLOWED_ORIGINS=https://decaflow.xyz,https://decaflow.vercel.app
