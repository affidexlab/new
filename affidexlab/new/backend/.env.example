# Environment
NODE_ENV=production
ENVIRONMENT=production

# Server
PORT=3000

# CORS - Allowed Origins (comma-separated, no spaces)
ALLOWED_ORIGINS=https://decaflow.xyz,https://decaflow.vercel.app,https://tychiwallet.com,https://app.tychiwallet.com

# API Keys
SOCKET_API_KEY=your_socket_api_key_here
ZEROX_API_KEY=your_0x_api_key_here

# Rate Limiting (optional overrides)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
